{
  "schemaVersion": "2.0.0",
  "strictness": "standard",
  "laneAllowlists": {
    "app-ui": [
      "app/**",
      "themes/**"
    ],
    "engine-finance": [
      "core/**",
      "processing/**",
      "ingestion/**",
      "mapping/**",
      "mapping_tables/**",
      "spread/**",
      "validation/**",
      "engine/**",
      "templates/**"
    ],
    "ops-quality": [
      ".github/**",
      ".claude/**",
      "docs/**",
      "scripts/**",
      "assets/**",
      "tests/**",
      "*.md",
      "LICENSE",
      ".gitignore",
      "data/test_samples/**"
    ],
    "master": [
      "app/**",
      "themes/**",
      "core/**",
      "processing/**",
      "ingestion/**",
      "mapping/**",
      "mapping_tables/**",
      "spread/**",
      "validation/**",
      "engine/**",
      "templates/**",
      ".github/**",
      ".claude/**",
      "docs/**",
      "scripts/**",
      "assets/**",
      "tests/**",
      "*.md",
      "LICENSE",
      ".gitignore",
      "data/test_samples/**"
    ]
  },
  "criticalGroups": [
    {
      "name": "shared-governance",
      "description": "Shared governance and documentation boundaries",
      "patterns": [
        "AGENTS.md",
        "README.md",
        "CONTEXT.md",
        "MEMORIADASIA.md",
        "CONTRIBUTING.md",
        "CHANGELOG.md",
        "LICENSE",
        ".gitignore",
        "build.spec",
        "requirements.txt",
        "main.py",
        "docs/**",
        ".github/ISSUE_TEMPLATE/**",
        ".github/PULL_REQUEST_TEMPLATE.md",
        ".claude/**"
      ],
      "ownerLane": "ops-quality",
      "allowedLanes": [
        "master",
        "app-ui",
        "ops-quality",
        "engine-finance"
      ],
      "minimumRisk": "shared",
      "requireDraft": true,
      "requireCompatibility": false
    },
    {
      "name": "critical-bootstrap",
      "description": "Setup and bootstrap-sensitive paths",
      "patterns": [
        ".github/workflows/**",
        ".github/guardrails/**",
        ".github/governance.config.yaml",
        "scripts/bootstrap-governance.ps1",
        "scripts/bootstrap-governance.sh",
        "scripts/worktree_create.ps1",
        "scripts/worktree_status.ps1",
        "scripts/worktree_remove.ps1",
        "scripts/pr_complete.ps1"
      ],
      "ownerLane": "ops-quality",
      "allowedLanes": [
        "master",
        "ops-quality"
      ],
      "minimumRisk": "shared",
      "requireDraft": true,
      "requireCompatibility": false
    },
    {
      "name": "critical-runtime",
      "description": "Core runtime, mapping, ingestion, validation, and spread execution paths",
      "patterns": [
        "core/**",
        "processing/**",
        "ingestion/**",
        "mapping/**",
        "mapping_tables/**",
        "spread/**",
        "validation/**",
        "engine/**",
        "templates/**"
      ],
      "ownerLane": "engine-finance",
      "allowedLanes": [
        "master",
        "engine-finance"
      ],
      "minimumRisk": "shared",
      "requireDraft": true,
      "requireCompatibility": false
    },
    {
      "name": "critical-contract",
      "description": "Public API and compatibility-sensitive paths",
      "patterns": [
        "core/conta_map.py",
        "core/utils.py",
        "processing/pipeline.py"
      ],
      "ownerLane": "engine-finance",
      "allowedLanes": [
        "master",
        "engine-finance"
      ],
      "minimumRisk": "contract-sensitive",
      "requireDraft": true,
      "requireCompatibility": true
    }
  ],
  "disallowedDomainMixes": [
    {
      "name": "app-ui-with-engine-runtime",
      "left": [
        "app/**"
      ],
      "right": [
        "core/**",
        "processing/**",
        "ingestion/**",
        "mapping/**",
        "mapping_tables/**",
        "spread/**",
        "validation/**",
        "engine/**",
        "templates/**"
      ],
      "exemptLanes": [
        "master"
      ]
    }
  ]
}