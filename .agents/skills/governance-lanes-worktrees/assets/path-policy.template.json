{
  "schemaVersion": "2.0.0",
  "strictness": "standard",
  "laneAllowlists": {
    "frontend": [
      "apps/web/**",
      "web/**",
      "frontend/**"
    ],
    "backend": [
      "apps/api/**",
      "api/**",
      "src/**",
      "backend/**",
      "services/**",
      "desktop/**",
      "dashboard/**",
      "tests/**"
    ],
    "ops-quality": [
      ".github/**",
      "docs/**",
      "scripts/**",
      "config/**",
      "*.md"
    ]
  },
  "criticalGroups": [
    {
      "name": "shared-governance",
      "description": "Shared governance and documentation boundaries",
      "patterns": [
        "AGENTS.md",
        "CLAUDE.md",
        "README.md",
        "docs/**",
        ".github/**"
      ],
      "ownerLane": "ops-quality",
      "allowedLanes": [
        "frontend",
        "backend",
        "ops-quality"
      ],
      "minimumRisk": "shared",
      "requireDraft": true,
      "requireCompatibility": false
    },
    {
      "name": "critical-bootstrap",
      "description": "Setup and bootstrap-sensitive paths",
      "patterns": [
        "scripts/setup_db.py",
        "scripts/runtime_doctor.py",
        "scripts/db_portability_smoke.py"
      ],
      "ownerLane": "ops-quality",
      "allowedLanes": [
        "ops-quality",
        "backend"
      ],
      "minimumRisk": "shared",
      "requireDraft": true,
      "requireCompatibility": false
    },
    {
      "name": "critical-runtime",
      "description": "Core runtime execution paths",
      "patterns": [
        "src/**"
      ],
      "ownerLane": "backend",
      "allowedLanes": [
        "backend"
      ],
      "minimumRisk": "shared",
      "requireDraft": true,
      "requireCompatibility": false
    },
    {
      "name": "critical-contract",
      "description": "Public API and compatibility-sensitive paths",
      "patterns": [
        "apps/api/**"
      ],
      "ownerLane": "backend",
      "allowedLanes": [
        "backend"
      ],
      "minimumRisk": "contract-sensitive",
      "requireDraft": true,
      "requireCompatibility": true
    }
  ],
  "disallowedDomainMixes": [
    {
      "name": "frontend-with-backend-runtime",
      "left": [
        "apps/web/**"
      ],
      "right": [
        "src/**",
        "apps/api/**",
        "desktop/**",
        "dashboard/**"
      ]
    }
  ]
}
